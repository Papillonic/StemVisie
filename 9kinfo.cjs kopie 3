const fs = require("fs");
const path = require("path");
const https = require("https");
const pdfjsLib = require("pdfjs-dist/legacy/build/pdf.js");

const BASE_URL = "https://gegevensmagazijn.tweedekamer.nl/OData/v4/2.0";

const filePath = path.join(__dirname, "src/lib/mockData.ts");
const raw = fs.readFileSync(filePath, "utf8");

// --------------------
// parse mockData
// --------------------
const start = raw.indexOf("mockAmendments");
const arrayStart = raw.indexOf("[", start);
const arrayEnd = raw.indexOf("];", arrayStart);

const data = eval("(" + raw.slice(arrayStart, arrayEnd + 1) + ")");

// --------------------
// ONLY MATCHES FILTER (BELANGRIJK)
// --------------------
const matches = data.filter((item) => {
  const title = (item?.title || "").trim();
  const full = item?.fullDescription || "";
  return title && full && full.startsWith(title);
});

console.log(`✅ Matches gevonden: ${matches.length}`);

// --------------------
// helpers
// --------------------
function fetchData(url) {
  return new Promise((resolve, reject) => {
    https.get(url, (res) => {
      let data = "";
      res.on("data", c => data += c);
      res.on("end", () => {
        try {
          resolve(JSON.parse(data));
        } catch (e) {
          reject(e);
        }
      });
    }).on("error", reject);
  });
}

function downloadPdf(url) {
  return new Promise((resolve, reject) => {
    https.get(url, (res) => {
      if (res.statusCode !== 200) {
        return reject(new Error("PDF not found"));
      }

      const chunks = [];
      res.on("data", c => chunks.push(c));
      res.on("end", () => resolve(new Uint8Array(Buffer.concat(chunks))));
    }).on("error", reject);
  });
}

async function extractText(data) {
  const pdf = await pdfjsLib.getDocument({ data }).promise;

  let text = "";
  for (let i = 1; i <= pdf.numPages; i++) {
    const page = await pdf.getPage(i);
    const content = await page.getTextContent();
    text += content.items.map(i => i.str).join(" ") + "\n";
  }

  return text;
}

// --------------------
// API → PDF url
// --------------------
async function getPdfUrl(query) {
  const url =
    `${BASE_URL}/Zaak?` +
    `$top=1&$filter=contains(Onderwerp,'${encodeURIComponent(query)}')` +
    `&$expand=Kamerstukdossier($select=Nummer,Toevoeging),Besluit` +
    `&$select=Volgnummer`;

  const res = await fetchData(url);
  const item = res.value?.[0];

  if (!item) return null;

  const dossier = item.Kamerstukdossier?.[0];
  if (!dossier?.Nummer) return null;

  const parts = [dossier.Nummer];
  if (dossier.Toevoeging) parts.push(dossier.Toevoeging);
  if (item.Volgnummer) parts.push(item.Volgnummer);

  return {
    pdfUrl: `https://zoek.officielebekendmakingen.nl/kst-${parts.join("-")}.pdf`
  };
}

// --------------------
// MAIN
// --------------------
(async () => {
  const enriched = [];

  for (const item of matches) {
    console.log(`🔄 Processing: ${item.id}`);

    try {
      const meta = await getPdfUrl(item.title);

      if (!meta) {
        console.log("❌ Geen PDF gevonden");
        enriched.push(item);
        continue;
      }

      const pdfData = await downloadPdf(meta.pdfUrl);
      const text = await extractText(pdfData);

      enriched.push({
        ...item,
        fullDescription: text,
        pdfUrl: meta.pdfUrl,
      });

      console.log("✅ PDF verwerkt");

    } catch (err) {
      console.log("⚠️ error:", err.message);
      enriched.push(item);
    }
  }

  const output =
    `export const mockAmendments = ` +
    JSON.stringify(enriched, null, 2) +
    `;\n`;

  const outPath = path.join(__dirname, "src/lib/mockData.enriched.ts");
  fs.writeFileSync(outPath, output, "utf8");

  console.log("\n🎉 Klaar: alleen matched IDs verwerkt");
})();